# @role workflow
# @owns pull-request and branch validation for Cloudflare Pages build health, generated architecture artifacts, code-path coverage manifests, and repo-context generation
# @not-owns production deployment, runtime behavior, or branch protection settings
# @notes Validates generated architecture artifacts, coverage manifests, focused context configuration, and the static Cloudflare Pages build. Pull-request runs wait for the branch's generated-artifact refresh workflow to settle, then re-checkout the latest PR head with full history before enforcing strict freshness checks.

name: Branch Validation

on:
  pull_request:
  push:
    branches-ignore:
      - main
    paths-ignore:
      - repo-context.xml
      - ci-context.xml
      - architecture/target-architecture.md
      - architecture/contexts/**
      - architecture/context-manifests/**
  workflow_dispatch:

permissions:
  contents: read
  actions: read

concurrency:
  group: ci-${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

jobs:
  validate:
    name: ci-validate
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v5
        with:
          fetch-depth: 0
          ref: ${{ github.event_name == 'pull_request' && github.event.pull_request.head.sha || github.sha }}

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: 22
          cache: npm

      - name: Wait for generated-artifact refresh workflow on pull requests
        id: wait_for_artifact_refresh
        if: github.event_name == 'pull_request'
        run: >
          node scripts/ci/wait-for-branch-workflow.mjs
          --repo "${REPO}"
          --branch "${BRANCH_NAME}"
          --workflow-path ".github/workflows/update-generated-artifacts.yml"
          --timeout-seconds "900"
          --poll-seconds "10"
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          REPO: ${{ github.repository }}
          BRANCH_NAME: ${{ github.head_ref }}

      - name: Re-checkout latest pull-request head with full history
        if: github.event_name == 'pull_request'
        uses: actions/checkout@v5
        with:
          fetch-depth: 0
          ref: ${{ steps.wait_for_artifact_refresh.outputs.latest_head_sha }}

      - name: Install dependencies
        run: npm ci

      - name: Validate architecture metadata and focus element policy
        run: node scripts/architecture/validate-architecture-consistency.mjs --branch "${BRANCH_NAME}" --require-focus-update
        env:
          BRANCH_NAME: ${{ github.head_ref || github.ref_name }}
          GITHUB_BASE_REF: ${{ github.base_ref }}

      - name: Generate target architecture
        run: node scripts/architecture/generate-target-architecture.mjs

      - name: Generate architecture context configs and coverage manifests
        run: node scripts/architecture/generate-context-configs.mjs --branch "${BRANCH_NAME}"
        env:
          BRANCH_NAME: ${{ github.head_ref || github.ref_name }}

      - name: Generate repo context
        run: npx --yes repomix --config repomix.config.json

      - name: Generate CI context
        run: npx --yes repomix --config ci-context.repomix.config.json

      - name: Generate architectural element contexts
        run: |
          for config in .tmp/architecture-context-configs/*.config.json; do
            echo "Generating context from $config"
            npx --yes repomix --config "$config"
          done

      - name: Check generated artifact freshness
        shell: bash
        run: |
          if git diff --quiet -- \
            repo-context.xml \
            ci-context.xml \
            architecture/target-architecture.md \
            architecture/contexts \
            architecture/context-manifests; then
            echo "Generated artifacts are current."
            exit 0
          fi

          echo "Generated artifacts differ from the committed versions in this checkout."
          echo "This does not necessarily mean GitHub is missing commits."
          echo "It means regenerating artifacts in CI produced different bytes than the tracked files."
          echo "Common causes are nondeterministic generation, generator changes without refreshed outputs, or checkout-sensitive generation."
          echo ""
          echo "Changed generated files:"
          git diff --name-only -- \
            repo-context.xml \
            ci-context.xml \
            architecture/target-architecture.md \
            architecture/contexts \
            architecture/context-manifests
          echo ""
          echo "Diff summary:"
          git diff --stat -- \
            repo-context.xml \
            ci-context.xml \
            architecture/target-architecture.md \
            architecture/contexts \
            architecture/context-manifests
          echo ""

          if [ "${{ github.event_name }}" = "push" ]; then
            echo "This is a branch push."
            echo "The 'Update Generated Artifacts' workflow should commit refreshed outputs automatically."
            echo "Continuing without failing this job."
            exit 0
          fi

          echo "This is a pull request after waiting for branch artifact refresh workflows to settle."
          echo "Generated artifacts must be reproducible and match the committed versions before merge."
          exit 1

      - name: Explain generated artifact behavior on branch pushes
        if: github.event_name == 'push'
        run: |
          echo "Branch pushes use a self-healing artifact flow."
          echo "If generated artifacts are stale, the dedicated 'Update Generated Artifacts' workflow commits contexts and coverage manifests back to the branch."

      - name: Build static app for Cloudflare Pages
        run: npm run build
        env:
          BASE_PATH: ""
</file>

<file path=".github/workflows/update-generated-artifacts.yml">
# @role workflow
# @owns regeneration and commit-back of generated repository contexts, code-path coverage manifests, and architecture artifacts on non-main branch updates
# @not-owns production deployment, runtime behavior, or branch protection settings
# @notes Generates repo-context.xml, ci-context.xml, target architecture, focused architecture contexts, and coverage manifests, then commits refreshed artifacts back to the branch when they change.

name: Update Generated Artifacts

on:
  push:
    branches-ignore:
      - main
    paths-ignore:
      - repo-context.xml
      - ci-context.xml
      - architecture/target-architecture.md
      - architecture/contexts/**
      - architecture/context-manifests/**
  workflow_dispatch:

permissions:
  contents: write

concurrency:
  group: update-generated-artifacts-${{ github.ref }}
  cancel-in-progress: true

jobs:
  generate:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout current branch
        uses: actions/checkout@v5
        with:
          fetch-depth: 0

      - name: Setup Node
        uses: actions/setup-node@v4
        with:
          node-version: 22
          cache: npm

      - name: Install dependencies
        run: npm ci

      - name: Generate target architecture
        run: node scripts/architecture/generate-target-architecture.mjs

      - name: Generate architecture context configs and coverage manifests
        run: node scripts/architecture/generate-context-configs.mjs --branch "${BRANCH_NAME}"
        env:
          BRANCH_NAME: ${{ github.ref_name }}

      - name: Generate repo context
        run: npx --yes repomix --config repomix.config.json

      - name: Generate CI context
        run: npx --yes repomix --config ci-context.repomix.config.json

      - name: Generate architectural element contexts
        run: |
          for config in .tmp/architecture-context-configs/*.config.json; do
            echo "Generating context from $config"
            npx --yes repomix --config "$config"
          done

      - name: Compute safe artifact name
        shell: bash
        run: |
          raw_ref="${GITHUB_REF_NAME}"
          safe_ref="$(printf '%s' "$raw_ref" | sed 's/[\":<>|*?\\/\r\n]/-/g' | sed 's/--*/-/g' | sed 's/^-//' | sed 's/-$//')"

          if [ -z "$safe_ref" ]; then
            safe_ref="unnamed-ref"
          fi

          echo "safe_ref=$safe_ref" >> "$GITHUB_ENV"

      - name: Upload generated artifact bundle
        uses: actions/upload-artifact@v4
        with:
          name: generated-artifacts-${{ env.safe_ref }}
          path: |
            repo-context.xml
            ci-context.xml
            architecture/target-architecture.md
            architecture/contexts
            architecture/context-manifests
          if-no-files-found: error

      - name: Commit updated generated artifacts to branch
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"

          git add \
            repo-context.xml \
            ci-context.xml \
            architecture/target-architecture.md \
            architecture/contexts \
            architecture/context-manifests

          if git diff --cached --quiet; then
            echo "No generated artifact changes."
            exit 0
          fi

          git commit -m "chore: refresh generated artifacts"
          git push origin HEAD:${GITHUB_REF_NAME}
</file>

